# =============================================================================
# FastMark — file môi trường dùng chung (Expo app + Backend + Web admin)
# Copy file này thành .env ở thư mục gốc dự án (FastMark/.env)
# =============================================================================

# --- Backend server ---
PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fastmark?retryWrites=true&w=majority

# --- API URL ---
# Expo: thiết bị thật dùng http://<IP-máy-tính>:5000 (ipconfig → IPv4)
# Emulator Android: app tự dùng http://10.0.2.2:5000
EXPO_PUBLIC_NODE_API_URL=http://10.0.2.2:5000
# Web admin (trình duyệt trên cùng máy chạy backend)
VITE_API_URL=http://localhost:5000

# --- Firebase client (Expo + Web đọc EXPO_PUBLIC_*) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=fastmark-e881d.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=fastmark-e881d
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=3127291193
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=fastmark-e881d.firebasestorage.app

# --- Google OAuth (Expo) ---
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=3127291193-vapc6989v56ove18gbib336mpf8aruk4.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=3127291193-94001sfai3r77epe21kd2ngu5qmrrul2.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# --- Supabase client (Expo upload ảnh) ---
EXPO_PUBLIC_SUPABASE_URL=https://yaqmfnnqfojsqnpngyct.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Firebase Admin SDK (Backend) ---
FIREBASE_PROJECT_ID=fastmark-e881d
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_API_KEY=

# --- Supabase server (Backend upload) ---
SUPABASE_STORAGE_BUCKET=product-images
SUPABASE_URL=https://yaqmfnnqfojsqnpngyct.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- SMTP (Backend gửi email xác minh) ---
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
