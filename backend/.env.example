PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/fastmark

# Firebase project — dùng để verify ID token từ app (auth only)
FIREBASE_PROJECT_ID=fastmark-e881d

# Tùy chọn: service account JSON file (Firebase Console → Project settings → Service accounts)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Hoặc paste JSON một dòng (không khuyến khích commit file này)
# FIREBASE_SERVICE_ACCOUNT_JSON=
